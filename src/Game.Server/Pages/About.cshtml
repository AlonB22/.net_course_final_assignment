@page
@model AboutModel
@{
    ViewData["Title"] = "About";
}

<section class="row justify-content-center">
    <div class="col-lg-8">
        <div class="feature-card p-4 p-lg-5">
            <span class="eyebrow">Submission details</span>
            <h1 class="h2 mt-3">About this assignment submission</h1>
            <p class="mt-3">
                Replace the placeholders below with your real submission details before final delivery.
            </p>

            <div class="row g-3 mt-4">
                <div class="col-md-6">
                    <div class="info-tile">
                        <div class="label">Submitter 1</div>
                        <div class="value">Your full name</div>
                        <div class="text-muted small">Student ID: 123456789</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-tile">
                        <div class="label">Submitter 2</div>
                        <div class="value">Partner name or "N/A"</div>
                        <div class="text-muted small">Student ID: 987654321</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-tile">
                        <div class="label">Course</div>
                        <div class="value">10212 .NET Programming</div>
                        <div class="text-muted small">Semester A 2026</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-tile">
                        <div class="label">Implementation stack</div>
                        <div class="value">Razor Pages, Web API, WinForms, EF Core</div>
                        <div class="text-muted small">LocalDB-backed server and client replay store</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
